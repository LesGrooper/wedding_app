# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*
.env
**/package-lock.json

# Di-generate dari .env oleh scripts/generate-env.mjs — berisi data pribadi
/src/environments/environment.ts
/src/environments/environment.prod.ts

# Kredensial Google Cloud service account — JANGAN pernah di-commit
wedding-app-*.json
*-service-account*.json

/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www
/.angular

resources/ios/**/*
resources/android/**/*

/.scannerwork
/.nx
/.env
/.editorconfig
apps-script
scripts