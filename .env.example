# ============================================================
# Template .env — salin jadi `.env` lalu isi nilainya:
#   cp .env.example .env
# Lalu generate environment files:
#   pnpm run config:env
# ============================================================

# Apps Script Web App endpoint (/exec) — lihat apps-script/README.md
APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
# Opsional: override khusus build production
# APPS_SCRIPT_URL_PROD=

# Tanggal & jam acara (ISO 8601 dengan timezone)
EVENT_DATE=2026-01-01T10:00:00+07:00
# Opsional: override khusus build production
# EVENT_DATE_PROD=

# Mempelai pria
GROOM_NAME=Nama Mempelai Pria
GROOM_PARENTS=Putra dari Bapak ... & Ibu ...
GROOM_PHOTO=assets/images/groom.jpg

# Mempelai wanita
BRIDE_NAME=Nama Mempelai Wanita
BRIDE_PARENTS=Putri dari Bapak ... & Ibu ...
BRIDE_PHOTO=assets/images/bride.jpg

# Lokasi acara
VENUE_NAME=Nama Gedung / Venue
VENUE_ADDRESS=Jl. Contoh No. 1, Kota
VENUE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
VENUE_MAPS_OPEN_URL=https://maps.google.com/?q=...

# Love story — urut dari 1; tambah blok STORY_5_* dst. kalau perlu
STORY_1_LABEL=Bab Pertama
STORY_1_TEXT=Tulis cerita di sini.
STORY_2_LABEL=Bab Kedua
STORY_2_TEXT=Tulis cerita di sini.
